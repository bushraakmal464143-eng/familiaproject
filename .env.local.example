# Acceso admin (mismo login que clientes en /cuenta/login)
ADMIN_EMAIL=adminofertas123@gmail.com
ADMIN_PASSWORD="Admin@$#123"

# Secreto para firmar sesiones (admin, campings, clientes)
# Debe coincidir con backend/.env
ADMIN_SECRET=una-cadena-larga-y-aleatoria

# API Express (registro / login con MongoDB)
BACKEND_URL=http://localhost:4000

# Demo campings (email @demo.campolibres): contraseña camping123
# Panel camping: /camping/login
# Panel cliente: /cuenta/login (crear cuenta nueva)

# Formulario "Más información" (envío a contactEmail de site-settings)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=tu-usuario
# SMTP_PASS=tu-contraseña

# Google sign-in (cliente) — https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=tu-client-secret
# Redirect URI autorizada: http://localhost:3000/api/auth/google/callback
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
